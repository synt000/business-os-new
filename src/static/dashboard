<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Business OS - Advanced Control Center</title>
<!-- Tailwind CSS & Chart.js CDN Engines Injection -->
<script src="https://jsdelivr.net"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif}
body{background:#f8fafc;color:#1e293b;display:flex;min-height:100vh}

/* Advanced Sidebar UI Navigation Matrix */
.sidebar{width:280px;background:#0f172a;color:#f8fafc;padding:25px 20px;display:flex;flex-direction:column;justify-content:between}
.sidebar-top h2{font-size:22px;color:#38bdf8;font-weight:800;margin-bottom:35px;display:flex;align-items:center;gap:10px}
.nav-group{margin-bottom:25px}
.group-title{font-size:11px;color:#64748b;text-transform:uppercase;font-weight:700;letter-spacing:1px;margin-bottom:12px;padding-left:10px}
.nav-link{display:flex;align-items:center;gap:12px;padding:12px 15px;color:#94a3b8;text-decoration:none;border-radius:10px;margin-bottom:6px;font-weight:600;transition:all 0.2s}
.nav-link.active, .nav-link:hover{background:#1e293b;color:#38bdf8;border-left:4px solid #38bdf8}

/* Profile Section Node */
.user-profile{background:#1e293b;padding:15px;border-radius:12px;display:flex;align-items:center;gap:12px}
.avatar{width:40px;height:40px;background:#38bdf8;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:bold;color:#0f172a}

/* Main System Analytics Content Workspace */
.main-content{flex:1;padding:40px;overflow-y:auto}
.header-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:35px}
.header-bar h1{font-size:28px;font-weight:800;color:#0f172a}
.status-badge{background:#e0f2fe;color:#0369a1;padding:6px 14px;border-radius:50px;font-size:13px;font-weight:700}

/* KPI Summary Deck Metrics */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:25px;margin-bottom:35px}
.kpi-card{background:#fff;padding:25px;border-radius:16px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);border:1px solid #e2e8f0;position:relative;overflow:hidden}
.kpi-card::after{content:'';position:absolute;top:0;left:0;width:100%;height:4px;background:#38bdf8}
.kpi-card.success::after{background:#10b981}
.kpi-card.warning::after{background:#f59e0b}
.kpi-title{font-size:13px;color:#64748b;margin-bottom:8px;text-transform:uppercase;font-weight:700;letter-spacing:0.5px}
.kpi-value{font-size:32px;font-weight:800;color:#0f172a}

/* Visual Interactive Analytic Layout Charts */
.chart-section{display:grid;grid-template-columns:2fr 1fr;gap:25px;margin-bottom:35px}
.chart-box{background:#fff;padding:25px;border-radius:16px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);border:1px solid #e2e8f0}
.chart-box h3{font-size:18px;font-weight:700;margin-bottom:20px;color:#0f172a}

/* Operational Data Tables UI */
.data-table-box{background:#fff;padding:25px;border-radius:16px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);border:1px solid #e2e8f0}
.data-table-box h3{font-size:18px;font-weight:700;margin-bottom:20px}
.custom-table{width:100%;border-collapse:collapse;text-align:left}
.custom-table th{background:#f8fafc;padding:14px 18px;color:#64748b;font-size:13px;font-weight:700;text-transform:uppercase}
.custom-table td{padding:14px 18px;border-bottom:1px solid #edf2f7;font-size:14px;color:#334155}

@media(max-width:1024px){
    .chart-section{grid-template-columns:1fr}
}
@media(max-width:768px){
    body{flex-direction:column}
    .sidebar{width:100%;min-height:auto}
}
</style>
</head>
<body>

<!-- Sidebar Workspace Node Container -->
<div class="sidebar">
    <div class="sidebar-top">
        <h2>🚀 Business OS</h2>
        
        <div class="nav-group">
            <div class="group-title">Core Management</div>
            <a href="#" class="nav-link active">📊 Dashboard Overview</a>
            <a href="/rentals/items" class="nav-link">🚗 Rental Fleet</a>
            <a href="/inventory/alerts/low-stock" class="nav-link">📦 Stock Alerts</a>
        </div>

        <div class="nav-group">
            <div class="group-title">SaaS Billing</div>
            <a href="/subscription/status" class="nav-link">💳 Plan Status</a>
            <a href="/payment/verify" class="nav-link">💸 Gateway Logs</a>
        </div>
    </div>

    <!-- Live Profile Entity -->
    <div class="user-profile">
        <div class="avatar">EO</div>
        <div>
            <div style="font-size:14px; font-weight:700;">Owner Workspace</div>
            <div style="font-size:11px; color:#64748b;">Enterprise Plan</div>
        </div>
    </div>
</div>

<!-- Main System Live Dashboard -->
<div class="main-content">
    <div class="header-bar">
        <div>
            <h1>Ecosystem Control Panel</h1>
            <p style="color:#64748b; margin-top:4px;">Multi-Tenant Instance Management Terminal Live</p>
        </div>
        <div class="status-badge">🟢 Node Status: Active</div>
    </div>

    <!-- Metric Deck Summary -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-title">Gross SaaS Revenue</div>
            <div class="kpi-value">Ks 450,000</div>
        </div>
        <div class="kpi-card success">
            <div class="kpi-title">Active Fleet Lease</div>
            <div class="kpi-value">12 Units</div>
        </div>
        <div class="kpi-card warning">
            <div class="kpi-title">Critical Stock Alert</div>
            <div class="kpi-value">3 Skus</div>
        </div>
    </div>

    <!-- Chart Visualization Array -->
    <div class="chart-section">
        <div class="chart-box">
            <h3>Revenue Growth Pipeline</h3>
            <canvas id="revenueChart" height="110"></canvas>
        </div>
        <div class="chart-box">
            <h3>Fleet Deployment</h3>
            <canvas id="fleetChart"></canvas>
        </div>
    </div>

    <!-- Operational System Activity Stream Log -->
    <div class="data-table-box">
        <h3>Ecosystem Activity Stream Logs</h3>
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Sub-System Domain</th>
                    <th>Operation Status Matrix</th>
                    <th>Telemetry Verification</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>2026-07-15 16:34</td>
                    <td><span style="color:#0284c7; font-weight:700;">BILLING_CORE</span></td>
                    <td>Subscription updated to STANDARD_MONTHLY successfully</td>
                    <td><span style="color:#16a34a; font-weight:700;">[✓] VERIFIED</span></td>
                </tr>
                <tr>
                    <td>2026-07-15 16:12</td>
                    <td><span style="color:#eab308; font-weight:700;">RENTAL_FLEET</span></td>
                    <td>Toyota Alphard (SaaS Fleet) allocation mapped to instance</td>
                    <td><span style="color:#16a34a; font-weight:700;">[✓] SUCCESS</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Interactive Chart Data Logic Compilation Script -->
<script>
const ctxRev = document.getElementById('revenueChart').getContext('2d');
new Chart(ctxRev, {
    type: 'line',
    data: {
        labels: ['May', 'Jun', 'Jul Plan', 'Current Live'],
        datasets: [{
            label: 'Monthly Growth (Ks)',
            data:,
            borderColor: '#38bdf8',
            backgroundColor: 'rgba(56, 189, 248, 0.1)',
            borderWidth: 3,
            fill: true,
            tension: 0.4
        }]
    },
    options: { responsive: true, plugins: { legend: { display: false } } }
});

const ctxFleet = document.getElementById('fleetChart').getContext('2d');
new Chart(ctxFleet, {
    type: 'doughnut',
    data: {
        labels: ['Available', 'Rented', 'Maintenance'],
        datasets: [{
            data:,
            backgroundColor: ['#10b981', '#38bdf8', '#f59e0b'],
            borderWidth: 0
        }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
});
</script>

</body>
</html>
