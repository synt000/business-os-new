from sqlalchemy.orm import Session

from src.models.saas_core import (
    Payment,
    Invoice,
    AccountLedger,
    Receivable,
)


def create_payment(
    db: Session,
    tenant_id: str,
    data,
):

    invoice = (
        db.query(Invoice)
        .filter(
            Invoice.id == data.invoice_id,
            Invoice.tenant_id == tenant_id,
        )
        .first()
    )

    if not invoice:
        raise Exception("INVOICE_NOT_FOUND")

    payment = Payment(
        payment_number=data.payment_number,
        amount=data.amount,
        payment_method=data.payment_method,
        status="COMPLETED",
        invoice_id=invoice.id,
        tenant_id=tenant_id,
    )

    invoice.status = "PAID"

    order = invoice.order

    if not order or not order.customer_id:
        raise Exception("CUSTOMER_NOT_FOUND")


    receivable = (
        db.query(Receivable)
        .filter(
            Receivable.invoice_id == invoice.id,
            Receivable.tenant_id == tenant_id,
        )
        .first()
    )

    if not receivable:
        receivable = Receivable(
            customer_id=order.customer_id,
            invoice_id=invoice.id,
            total_amount=invoice.amount,
            paid_amount=0,
            balance_amount=invoice.amount,
            status="OPEN",
            tenant_id=tenant_id,
        )

        db.add(receivable)
        db.flush()


    receivable.paid_amount += data.amount

    receivable.balance_amount = (
        receivable.total_amount -
        receivable.paid_amount
    )


    if receivable.balance_amount <= 0:
        receivable.balance_amount = 0
        receivable.status = "PAID"
    else:
        receivable.status = "PARTIAL"


    ledger = AccountLedger(
        entry_type="INCOME",
        account_head="SALES_PAYMENT",
        amount=data.amount,
        reference_id=invoice.id,
        description=f"Payment received {data.payment_number}",
        tenant_id=tenant_id,
    )


    db.add(payment)
    db.add(ledger)

    db.commit()
    db.refresh(payment)

    return payment

