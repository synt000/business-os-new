<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Sales Orders - Business OS ERP</title>

<script src="https://cdn.tailwindcss.com"></script>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>
body{
font-family:Arial,sans-serif;
background:#090D16;
}

.card{
background:rgba(17,24,39,.7);
border:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(12px);
}
</style>

</head>


<body class="text-gray-100 min-h-screen">


<div class="p-6">

<h1 class="text-2xl font-bold mb-6">
🛒 Sales Order Node
</h1>


<div class="grid md:grid-cols-3 gap-6">


<div class="card rounded-2xl p-6">


<h2 class="text-sm font-bold text-gray-400 mb-5">
<i class="fa-solid fa-cart-plus"></i>
Place Sales Order
</h2>



<form id="order-form">


<label class="text-xs text-gray-400">
Customer
</label>

<select id="customer_id"
class="w-full mt-2 mb-4 bg-gray-900 border border-gray-700 rounded-xl p-3">

<option>
Loading customers...
</option>

</select>



<select
id="product"
class="w-full mt-2 mb-4 bg-gray-900 border border-gray-700 rounded-xl p-3">
</select>

<div
id="stock"
class="text-sm text-blue-400 mb-4">
Stock: -
</div>

<label class="text-xs text-gray-400">
Quantity
</label>

<input
id="quantity"
type="number"
value="1"
min="1"
class="w-full mt-2 mb-4 bg-gray-900 border border-gray-700 rounded-xl p-3">



<label class="text-xs text-gray-400">
Unit Price
</label>

<input
id="price"
readonly
class="w-full mt-2 mb-4 bg-gray-900 border border-gray-700 rounded-xl p-3">



<button
class="w-full bg-emerald-600 hover:bg-emerald-500 rounded-xl py-3 font-bold">

Process Order Invoice

</button>


</form>


<div id="toast"
class="mt-4 hidden p-3 rounded-xl text-sm">
</div>


</div>



<div class="md:col-span-2 card rounded-2xl p-6">


<div class="flex justify-between mb-5">

<h2 class="text-sm font-bold text-gray-400">
<i class="fa-solid fa-file-invoice"></i>
Corporate Invoice Journal
</h2>


<button id="refresh-btn"
class="bg-gray-800 px-4 py-2 rounded-xl text-xs">

Sync Journal

</button>


</div>



<table class="w-full text-sm">

<thead class="text-gray-500">

<tr>

<th class="text-left">
Order
</th>

<th>
Customer
</th>

<th>
Amount
</th>

<th>
Status
</th>

</tr>

</thead>


<tbody id="orders-table">

</tbody>


</table>


</div>


</div>


</div>

<script>

document.addEventListener("DOMContentLoaded",()=>{

const token=localStorage.getItem("access_token"); console.log("ERP TOKEN:", token);

const product=document.getElementById("product");
const customer=document.getElementById("customer_id");
const price=document.getElementById("price");
const stock=document.getElementById("stock");

let products=[];


async function loadProducts(){

const res=await fetch(
"/api/v4/business/products",
{
headers:{
"Authorization":"Bearer "+token
}
});

const data=await res.json();

products=data.products||[];

product.innerHTML="";


products.forEach(p=>{

let o=document.createElement("option");

o.value=p.id;

o.textContent=p.name+" ("+p.sku+")";

o.dataset.price=p.retail_price;

o.dataset.stock=p.stock_qty;

product.appendChild(o);

});


updateProduct();

}



function updateProduct(){

let o=product.options[product.selectedIndex];

if(!o)return;

price.value=o.dataset.price;

stock.innerText="Available Stock: "+o.dataset.stock;

}



product.onchange=updateProduct;


async function loadCustomers(){

const res=await fetch(
"/api/v4/business/customers",
{
headers:{
"Authorization":"Bearer "+token
}
});


const data=await res.json();


customer.innerHTML="";


(data.customers||[]).forEach(c=>{

let o=document.createElement("option");

o.value=c.id;

o.textContent=c.name;

customer.appendChild(o);

});


}





async function loadOrders(){

const res=await fetch(
"/api/v4/business/orders",
{
headers:{
"Authorization":"Bearer "+token
}
});


const data=await res.json();


const table=document.getElementById("orders-table");

table.innerHTML="";


(data.orders||[]).forEach(o=>{


table.innerHTML += `

<tr class="border-b border-gray-800">

<td class="py-3">
${o.order_number}
</td>

<td>
${o.customer}
</td>

<td>
$${o.total_usd}
</td>

<td>
<span class="px-2 py-1 rounded bg-gray-800">
${o.status}
</span>

${
o.status === "PENDING"
?
`<button
onclick="updateOrderStatus('${o.id}','CONFIRMED')"
class="ml-2 px-2 py-1 bg-blue-600 rounded text-xs">
Confirm
</button>`
:
o.status === "CONFIRMED"
?
`<button
onclick="updateOrderStatus('${o.id}','COMPLETED')"
class="ml-2 px-2 py-1 bg-green-600 rounded text-xs">
Complete
</button>`
:
``
}

</td>

</tr>

`;

});


}




document
.getElementById("order-form")
.addEventListener("submit",async(e)=>{


e.preventDefault();



const payload={

platform_channel:"POS",

customer_name:
customer.options[customer.selectedIndex]?.text
||"Walk In Customer",

customer_phone:null,

items:[

{

product_id:product.value,

quantity:
parseInt(
document.getElementById("quantity").value
)

}

]

};



const res=await fetch(

"/api/v4/business/orders",

{

method:"POST",

headers:{

"Content-Type":"application/json",

"Authorization":"Bearer "+token

},

body:JSON.stringify(payload)

}

);



const data=await res.json();



const toast=document.getElementById("toast");


toast.classList.remove("hidden");


if(res.ok){

toast.className=
"mt-4 p-3 rounded-xl bg-green-900 text-green-300";


toast.innerText=
"✓ Order Created : "+data.order_number;


loadProducts();

loadOrders();


}else{


toast.className=
"mt-4 p-3 rounded-xl bg-red-900 text-red-300";


toast.innerText=
"✗ "+data.detail;


}



});



document
.getElementById("refresh-btn")
.onclick=loadOrders;



loadProducts();

loadCustomers();

loadOrders();



});


</script>

</body>

</html>


<script>

async function updateOrderStatus(id,status){

const res = await fetch(
"/api/v4/business/orders/"+id+"/status",
{
method:"PATCH",
headers:{
"Content-Type":"application/json",
"Authorization":"Bearer "+token
},
body:JSON.stringify({
status:status
})
}
);

const data=await res.json();

alert(data.status || data.detail);

loadOrders();

}

</script>

