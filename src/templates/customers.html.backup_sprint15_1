<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">

<title>Customers - Business OS</title>

<link rel="stylesheet" href="/static/app.css">

</head>


<body>

<div class="container">

<h1>👥 Customers</h1>

<div class="card">

<table width="100%">

<thead>
<tr>
<th>Name</th>
<th>Phone</th>
<th>Email</th>
</tr>
</thead>


<tbody id="customerList">

</tbody>


</table>

</div>


<a href="/dashboard">
⬅ Dashboard
</a>


</div>



<script>

async function loadCustomers(){

const token =
localStorage.getItem("access_token");


const res =
await fetch(
"/api/v4/customers",
{
headers:{
"Authorization":
"Bearer "+token
}
}
);


if(!res.ok){

return;

}


const data =
await res.json();


const list =
document.getElementById(
"customerList"
);


data.customers.forEach(c=>{

list.innerHTML += `

<tr>

<td>${c.name}</td>

<td>${c.phone ?? ""}</td>

<td>${c.email ?? ""}</td>

</tr>

`;

});


}


loadCustomers();

</script>


</body>

</html>
