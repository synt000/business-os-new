from sqlalchemy.orm import Session

from src.domains.product.models import Product
from src.domains.order.models import Order
from src.domains.inventory.models import Inventory
from src.domains.movement.models import StockMovement

from src.models.saas_core import (
    Customer,
    Supplier,
    Category,
)


class DashboardService:
    """
    Enterprise Dashboard Metrics Service

    Tenant isolated realtime business metrics.
    """

    @staticmethod
    def get_summary(
        db: Session,
        tenant_id: str
    ):

        products = (
            db.query(Product)
            .filter(
                Product.tenant_id == tenant_id
            )
            .count()
        )


        orders = (
            db.query(Order)
            .filter(
                Order.tenant_id == tenant_id
            )
            .count()
        )


        inventory = (
            db.query(Inventory)
            .filter(
                Inventory.tenant_id == tenant_id
            )
            .count()
        )


        customers = (
            db.query(Customer)
            .filter(
                Customer.tenant_id == tenant_id
            )
            .count()
        )


        suppliers = (
            db.query(Supplier)
            .filter(
                Supplier.tenant_id == tenant_id
            )
            .count()
        )


        categories = (
            db.query(Category)
            .filter(
                Category.tenant_id == tenant_id
            )
            .count()
        )


        movements = (
            db.query(StockMovement)
            .filter(
                StockMovement.tenant_id == tenant_id
            )
            .order_by(
                StockMovement.created_at.desc()
            )
            .limit(5)
            .all()
        )


        return {

            "products": products,

            "orders": orders,

            "customers": customers,

            "suppliers": suppliers,

            "categories": categories,

            "inventory": inventory,

            "recent_movements": [

                {
                    "id": str(item.id),

                    "type": item.movement_type,

                    "quantity": item.quantity,

                    "created_at":
                        item.created_at.isoformat()
                        if item.created_at
                        else None
                }

                for item in movements

            ]

        }
