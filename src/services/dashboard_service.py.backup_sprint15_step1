from sqlalchemy.orm import Session

from src.models.saas_core import (
    Product,
    Category,
)


class DashboardService:
    """
    Enterprise Dashboard Metrics Service

    Tenant isolated dashboard aggregation.
    """

    @staticmethod
    def get_summary(
        db: Session,
        tenant_id: str
    ):

        product_count = (
            db.query(Product)
            .filter(
                Product.tenant_id == tenant_id
            )
            .count()
        )

        category_count = (
            db.query(Category)
            .filter(
                Category.tenant_id == tenant_id
            )
            .count()
        )


        return {
            "products": product_count,
            "categories": category_count,
            "recent_movements": []
        }
